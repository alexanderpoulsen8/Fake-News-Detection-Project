# Environment variables
.env

# Ignore all data by default
data/

# Re-allow directories so we can whitelist subtrees
!data/**/

# Always ignore raw
data/raw/**

# Allow processed outputs
!data/processed/**
!data/processed/**/*.csv
!data/processed/**/*.parquet
!data/processed/**/*.json
!data/processed/**/*.feather
!data/processed/**/*.pkl

# Keep .gitkeep
!.gitkeep
!data/**/.gitkeep
